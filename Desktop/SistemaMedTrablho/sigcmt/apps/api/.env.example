# ─────────────────────────────────────────
# SIGCMT API — variáveis de ambiente
# Copie para .env e preencha com seus valores
# ─────────────────────────────────────────

# Banco de dados — copie a connection string do Supabase:
# Supabase > Project Settings > Database > Connection string > URI (Transaction pooler)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connect_timeout=15"

# Para migrations (direct connection, sem pooler):
DATABASE_DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="troque-por-uma-chave-de-64-bytes-aleatoria"
JWT_EXPIRES_IN="15m"

# Servidor
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Frontend (CORS)
FRONTEND_URL=http://localhost:5173

# Supabase (para Storage e webhooks futuros)
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
